{
  "name": "java-structure-analyser",
  "displayName": "Java Structure Analyser",
  "description": "An interactive VS Code extension for building focused Java structure diagrams iteratively.",
  "version": "0.1.0",
  "publisher": "greengrasshopper-ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreenGrasshopper-AI/JavaStructureAnalyser.git"
  },
  "bugs": {
    "url": "https://github.com/GreenGrasshopper-AI/JavaStructureAnalyser/issues"
  },
  "homepage": "https://github.com/GreenGrasshopper-AI/JavaStructureAnalyser#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCommand:javaStructureAnalyser.openGraph"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "javaStructureAnalyser.openGraph",
        "title": "Java Structure Analyser: Open Graph"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "javaStructureAnalyser.openGraph",
          "when": "resourceLangId == java",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test test/**/*.test.js",
    "lint": "tsc --noEmit -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.7.2"
  }
}
